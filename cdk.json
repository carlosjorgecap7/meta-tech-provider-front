{
  "app": "npx ts-node --prefer-ts-exts bin/meta-tech-provider-front.ts",
  "watch": {
    "include": ["bin/**/*.ts", "lib/**/*.ts"],
    "exclude": [
      "README.md",
      "cdk*.json",
      "**/*.d.ts",
      "**/*.js",
      "tsconfig.json",
      "package*.json",
      "node_modules",
      "frontend"
    ]
  },
  "context": {
    "@aws-cdk/aws-s3:serverAccessLogsUseBucketPolicy": true,
    "@aws-cdk/aws-cloudfront:defaultSecurityPolicyTLSv1.2_2021": true
  }
}
